<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>Trevor Downs | Career Portfolio</title>

  <meta
    name="description"
    content="Explore Trevor Downs' experience across Salesforce, marketing automation, revenue operations, project delivery and organisational change."
  >

  <style>
    :root {
      --background: #f5f7fa;
      --surface: #ffffff;
      --text: #172033;
      --muted: #5c667a;
      --accent: #2457d6;
      --border: #dfe4ec;
      --max-width: 1120px;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      color: var(--text);
      background: var(--background);
      line-height: 1.6;
    }

    header {
      background: var(--surface);
      border-bottom: 1px solid var(--border);
    }

    nav {
      width: min(90%, var(--max-width));
      margin: 0 auto;
      min-height: 72px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
    }

    .brand {
      font-size: 1.1rem;
      font-weight: 700;
    }

    .nav-links {
      display: flex;
      gap: 20px;
    }

    .nav-links a {
      color: var(--text);
      text-decoration: none;
      font-weight: 600;
    }

    main {
      width: min(90%, var(--max-width));
      margin: 0 auto;
    }

    .hero {
      padding: 96px 0 72px;
      max-width: 820px;
    }

    .eyebrow {
      color: var(--accent);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-size: 0.85rem;
    }

    h1 {
      margin: 14px 0 20px;
      font-size: clamp(2.5rem, 7vw, 5rem);
      line-height: 1.05;
      letter-spacing: -0.04em;
    }

    .hero p {
      max-width: 700px;
      color: var(--muted);
      font-size: 1.2rem;
    }

    .button-row {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 32px;
    }

    .button {
      display: inline-block;
      padding: 12px 18px;
      border-radius: 8px;
      text-decoration: none;
      font-weight: 700;
      border: 1px solid var(--accent);
    }

    .button-primary {
      color: #ffffff;
      background: var(--accent);
    }

    .button-secondary {
      color: var(--accent);
      background: transparent;
    }

    .section {
      padding: 60px 0;
    }

    .section-heading {
      margin-bottom: 28px;
    }

    .section-heading h2 {
      margin-bottom: 8px;
      font-size: 2rem;
    }

    .section-heading p {
      margin: 0;
      color: var(--muted);
    }

    .search-panel {
      padding: 24px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 14px;
    }

    #search {
      width: 100%;
      padding: 15px;
      font: inherit;
      border: 1px solid var(--border);
      border-radius: 8px;
    }

    .filters {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 16px;
    }

    .filter-button {
      padding: 9px 13px;
      border: 1px solid var(--border);
      border-radius: 999px;
      background: var(--surface);
      color: var(--text);
      cursor: pointer;
    }

    .filter-button.active {
      color: #ffffff;
      background: var(--accent);
      border-color: var(--accent);
    }

    .project-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(270px, 1fr));
      gap: 20px;
      margin-top: 28px;
    }

    .project-card {
      padding: 24px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 14px;
    }

    .project-card h3 {
      margin-top: 0;
      margin-bottom: 10px;
    }

    .project-card p {
      color: var(--muted);
    }

    .tags {
      display: flex;
      flex-wrap: wrap;
      gap: 7px;
      margin-top: 18px;
    }

    .tag {
      padding: 5px 9px;
      border-radius: 6px;
      background: #edf2ff;
      color: #234ba5;
      font-size: 0.82rem;
      font-weight: 700;
    }

    footer {
      margin-top: 80px;
      padding: 32px 5%;
      text-align: center;
      color: var(--muted);
      border-top: 1px solid var(--border);
      background: var(--surface);
    }

    @media (max-width: 650px) {
      nav {
        align-items: flex-start;
        flex-direction: column;
        padding: 18px 0;
      }

      .nav-links {
        flex-wrap: wrap;
      }

      .hero {
        padding-top: 64px;
      }
    }
  </style>
</head>

<body>
  <header>
    <nav>
      <div class="brand">Trevor Downs</div>

      <div class="nav-links">
        <a href="#work">Work</a>
        <a href="#about">About</a>
        <a href="mailto:trevor.p.downs@gmail.com">Contact</a>
      </div>
    </nav>
  </header>

  <main>
    <section class="hero">
      <div class="eyebrow">Career portfolio</div>

      <h1>Commercial systems built around people, data and relationships.</h1>

      <p>
        I design and improve Salesforce, marketing automation and operational
        systems that connect customer relationships, commercial data and
        organisational processes.
      </p>

      <div class="button-row">
        <a class="button button-primary" href="#work">Explore my work</a>
        <a
          class="button button-secondary"
          href="https://www.linkedin.com/in/trevor-downs-77a65a2b0/"
          target="_blank"
          rel="noopener noreferrer"
        >
          LinkedIn
        </a>
      </div>
    </section>

    <section class="section" id="work">
      <div class="section-heading">
        <h2>Explore my experience</h2>
        <p>Search by technology, capability or type of project.</p>
      </div>

      <div class="search-panel">
        <label for="search"><strong>Search projects</strong></label>

        <input
          id="search"
          type="search"
          placeholder="Try Salesforce, MCAE, attribution or events"
        >

        <div class="filters">
          <button class="filter-button active" data-filter="all">All</button>
          <button class="filter-button" data-filter="Salesforce">Salesforce</button>
          <button class="filter-button" data-filter="MCAE">MCAE</button>
          <button class="filter-button" data-filter="Marketing">Marketing</button>
          <button class="filter-button" data-filter="Operations">Operations</button>
          <button class="filter-button" data-filter="Leadership">Leadership</button>
          <button class="filter-button" data-filter="Events">Events</button>
        </div>
      </div>

      <div class="project-grid" id="project-grid"></div>
    </section>

    <section class="section" id="about">
      <div class="section-heading">
        <h2>About</h2>
      </div>

      <p>
        My experience spans CRM architecture, Salesforce automation, marketing
        operations, revenue attribution, project leadership and large-scale
        event delivery. This portfolio allows you to explore the work most
        relevant to your organisation.
      </p>
    </section>
  </main>

  <footer>
    © 2026 Trevor Downs
  </footer>

  <script>
    const projects = [
      {
        title: "Salesforce multi-touch attribution model",
        category: "Salesforce",
        summary:
          "Designed a weighted attribution model connecting email, events, sales activity and organisational relationships.",
        tags: ["Salesforce", "Flow", "Attribution", "Revenue Operations"]
      },
      {
        title: "MCAE platform migration and rebuild",
        category: "MCAE",
        summary:
          "Built a governed marketing automation environment and migrated approximately 30,000 legacy contacts into 19,000 viable prospects.",
        tags: ["MCAE", "Pardot", "Migration", "Data Governance"]
      },
      {
        title: "Local-authority commercial data model",
        category: "Salesforce",
        summary:
          "Designed a Salesforce hierarchy spanning more than 1,000 accounts and over 20,000 leads and contacts.",
        tags: ["Salesforce", "Data Modelling", "Automation"]
      },
      {
        title: "Marketing campaign performance engine",
        category: "Marketing",
        summary:
          "Managed more than 50 campaigns and increased average email open rates from approximately 8% to 40%.",
        tags: ["Marketing", "Email", "Analytics", "MCAE"]
      },
      {
        title: "Youth event portfolio growth",
        category: "Events",
        summary:
          "Restructured event strategy, marketing and operations to triple average attendance and revive stalled programmes.",
        tags: ["Events", "Leadership", "Operations", "Marketing"]
      },
      {
        title: "International conference operations",
        category: "Operations",
        summary:
          "Managed operational delivery for multi-day international conferences attended by more than 30,000 people.",
        tags: ["Operations", "Events", "Risk Management", "Leadership"]
      }
    ];

    const projectGrid = document.getElementById("project-grid");
    const searchInput = document.getElementById("search");
    const filterButtons = document.querySelectorAll(".filter-button");

    let activeFilter = "all";

    function renderProjects() {
      const query = searchInput.value.trim().toLowerCase();

      const filteredProjects = projects.filter(project => {
        const searchableText = [
          project.title,
          project.category,
          project.summary,
          ...project.tags
        ].join(" ").toLowerCase();

        const matchesSearch = searchableText.includes(query);

        const matchesFilter =
          activeFilter === "all" ||
          searchableText.includes(activeFilter.toLowerCase());

        return matchesSearch && matchesFilter;
      });

      if (filteredProjects.length === 0) {
        projectGrid.innerHTML =
          "<p>No projects match that search. Try another keyword.</p>";
        return;
      }

      projectGrid.innerHTML = filteredProjects.map(project => `
        <article class="project-card">
          <h3>${project.title}</h3>
          <p>${project.summary}</p>

          <div class="tags">
            ${project.tags
              .map(tag => `<span class="tag">${tag}</span>`)
              .join("")}
          </div>
        </article>
      `).join("");
    }

    searchInput.addEventListener("input", renderProjects);

    filterButtons.forEach(button => {
      button.addEventListener("click", () => {
        activeFilter = button.dataset.filter;

        filterButtons.forEach(item => item.classList.remove("active"));
        button.classList.add("active");

        renderProjects();
      });
    });

    renderProjects();
  </script>
</body>
</html>
