const FILTER_TAGS = [
  "Marketing",
  "Automation",
  "Salesforce & CRM",
  "Data & Analytics",
  "Commercial Strategy",
  "Operations",
  "Leadership & Stakeholder Management",
  "Events & Engagement",
  "AI-Assisted Innovation"
];

const state = {
  projects: [],
  selectedTags: new Set(),
  searchQuery: "",
  sortOrder: "relevance"
};

const elements = {
  tagFilters: document.getElementById("tag-filters"),
  clearFilters: document.getElementById("clear-filters"),
  filterDescription: document.getElementById(
    "filter-description"
  ),
  search: document.getElementById("project-search"),
  sort: document.getElementById("sort-order"),
  grid: document.getElementById("project-grid"),
  resultCount: document.getElementById("result-count"),
  activeFilterSummary: document.getElementById(
    "active-filter-summary"
  ),
  emptyState: document.getElementById("empty-state"),
  currentYear: document.getElementById("current-year")
};

/*
  Protects content inserted into the page from
  accidentally being treated as HTML.
*/

function escapeHtml(value) {
  return String(value ?? "")
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;")
    .replace(/'/g, "&#039;");
}

function escapeAttribute(value) {
  return escapeHtml(value);
}

/*
  Converts punctuation and formatting differences
  into a consistent searchable format.

  Examples:

  Salesforce & CRM -> salesforce and crm
  Multi-Touch       -> multi touch
  Data-Quality      -> data quality
*/

function normaliseSearchText(value) {
  return String(value ?? "")
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/&/g, " and ")
    .replace(/[^a-z0-9]+/g, " ")
    .replace(/\s+/g, " ")
    .trim();
}

/*
  Turns arrays and nested objects into plain text.
  This allows the search to support either simple
  outcome strings or more detailed outcome objects.
*/

function flattenSearchValue(value) {
  if (value === null || value === undefined) {
    return [];
  }

  if (Array.isArray(value)) {
    return value.flatMap((item) => {
      return flattenSearchValue(item);
    });
  }

  if (typeof value === "object") {
    return Object.values(value).flatMap((item) => {
      return flattenSearchValue(item);
    });
  }

  return [String(value)];
}

/*
  Builds a reusable search index for one project.
*/

function buildProjectSearchData(project) {
  return {
    id: normaliseSearchText(project.id),

    title: normaliseSearchText(project.title),

    employer: normaliseSearchText(project.employer),

    summary: normaliseSearchText(project.summary),

    details: normaliseSearchText(project.details),

    metric: normaliseSearchText(
      project.featuredMetric
    ),

    tags: normaliseSearchText(
      flattenSearchValue(project.tags).join(" ")
    ),

    skills: normaliseSearchText(
      flattenSearchValue(project.skills).join(" ")
    ),

    tools: normaliseSearchText(
      flattenSearchValue(project.tools).join(" ")
    ),

    outcomes: normaliseSearchText(
      flattenSearchValue(project.outcomes).join(" ")
    )
  };
}

/*
  Creates one combined searchable string from all
  relevant project fields.
*/

function getCombinedSearchText(project) {
  const searchData =
    project._searchData ||
    buildProjectSearchData(project);

  return Object.values(searchData).join(" ");
}

/*
  Splits the search into individual words.

  "salesforce crm attribution" becomes:

  ["salesforce", "crm", "attribution"]

  The word "and" is ignored so Salesforce & CRM
  can be found by typing either:

  salesforce crm
  salesforce & crm
*/

function getSearchTerms() {
  const normalisedQuery =
    normaliseSearchText(state.searchQuery);

  if (!normalisedQuery) {
    return [];
  }

  return normalisedQuery
    .split(" ")
    .filter((term) => {
      return term && term !== "and";
    });
}

/*
  Builds the capability filter buttons.
*/

function createFilterButtons() {
  if (!elements.tagFilters) {
    return;
  }

  elements.tagFilters.innerHTML = FILTER_TAGS
    .map((tag) => {
      return `
        <button
          class="tag-filter"
          type="button"
          data-tag="${escapeAttribute(tag)}"
          aria-pressed="false"
        >
          ${escapeHtml(tag)}
        </button>
      `;
    })
    .join("");

  const filterButtons =
    elements.tagFilters.querySelectorAll(
      ".tag-filter"
    );

  filterButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const tag = button.dataset.tag;

      if (state.selectedTags.has(tag)) {
        state.selectedTags.delete(tag);
      } else {
        state.selectedTags.add(tag);
      }

      updateFilterButtons();
      renderProjects();
    });
  });
}

/*
  Updates the selected appearance and description
  whenever a filter is changed.
*/

function updateFilterButtons() {
  if (!elements.tagFilters) {
    return;
  }

  const filterButtons =
    elements.tagFilters.querySelectorAll(
      ".tag-filter"
    );

  filterButtons.forEach((button) => {
    const isActive =
      state.selectedTags.has(button.dataset.tag);

    button.classList.toggle(
      "active",
      isActive
    );

    button.setAttribute(
      "aria-pressed",
      String(isActive)
    );
  });

  if (!elements.filterDescription) {
    return;
  }

  const selectedTags = [...state.selectedTags];

  if (selectedTags.length === 0) {
    elements.filterDescription.textContent =
      "No filters selected. Showing all work.";

    return;
  }

  elements.filterDescription.textContent =
    `Matching every selected capability: ${
      selectedTags.join(" + ")
    }`;
}

/*
  Uses AND filtering.

  Selecting Salesforce & CRM and Automation means
  the project must contain both tags.
*/

function projectMatchesSelectedTags(project) {
  return [...state.selectedTags].every((tag) => {
    return (
      Array.isArray(project.tags) &&
      project.tags.includes(tag)
    );
  });
}

/*
  Every entered search word must appear somewhere
  in the project's searchable information.

  The words can appear:
  - in any order
  - in different fields
  - separated by punctuation
*/

function projectMatchesSearch(project) {
  const searchTerms = getSearchTerms();

  if (searchTerms.length === 0) {
    return true;
  }

  const searchableText =
    getCombinedSearchText(project);

  return searchTerms.every((term) => {
    return searchableText.includes(term);
  });
}

/*
  Calculates relevance when the recruiter searches.

  Matches in titles, tags and skills receive more
  weight than matches buried in longer descriptions.
*/

function calculateSearchRelevance(project) {
  const searchTerms = getSearchTerms();

  if (searchTerms.length === 0) {
    return Number(project.priority || 0);
  }

  const searchData =
    project._searchData ||
    buildProjectSearchData(project);

  let score = 0;

  searchTerms.forEach((term) => {
    if (searchData.title.includes(term)) {
      score += 20;
    }

    if (searchData.tags.includes(term)) {
      score += 16;
    }

    if (searchData.skills.includes(term)) {
      score += 14;
    }

    if (searchData.employer.includes(term)) {
      score += 9;
    }

    if (searchData.tools.includes(term)) {
      score += 9;
    }

    if (searchData.metric.includes(term)) {
      score += 7;
    }

    if (searchData.summary.includes(term)) {
      score += 6;
    }

    if (searchData.outcomes.includes(term)) {
      score += 5;
    }

    if (searchData.details.includes(term)) {
      score += 3;
    }

    if (searchData.id.includes(term)) {
      score += 1;
    }
  });

  const completeQuery =
    normaliseSearchText(state.searchQuery)
      .replace(/\band\b/g, " ")
      .replace(/\s+/g, " ")
      .trim();

  if (
    completeQuery &&
    searchData.title.includes(completeQuery)
  ) {
    score += 40;
  }

  score += Number(project.priority || 0);

  return score;
}

/*
  Sorts filtered projects.
*/

function sortProjects(projects) {
  const sortedProjects = [...projects];

  if (state.sortOrder === "newest") {
    return sortedProjects.sort(
      (projectA, projectB) => {
        return String(projectB.sortDate || "")
          .localeCompare(
            String(projectA.sortDate || "")
          );
      }
    );
  }

  if (state.sortOrder === "oldest") {
    return sortedProjects.sort(
      (projectA, projectB) => {
        return String(projectA.sortDate || "")
          .localeCompare(
            String(projectB.sortDate || "")
          );
      }
    );
  }

  return sortedProjects.sort(
    (projectA, projectB) => {
      const relevanceDifference =
        calculateSearchRelevance(projectB) -
        calculateSearchRelevance(projectA);

      if (relevanceDifference !== 0) {
        return relevanceDifference;
      }

      const priorityDifference =
        Number(projectB.priority || 0) -
        Number(projectA.priority || 0);

      if (priorityDifference !== 0) {
        return priorityDifference;
      }

      return String(projectB.sortDate || "")
        .localeCompare(
          String(projectA.sortDate || "")
        );
    }
  );
}

/*
  Creates each portfolio card.

  A card becomes clickable automatically when its
  projects.json object contains:

  "pageUrl": "project-page.html"
*/

function createProjectCard(project) {
  const pageUrl =
    String(project.pageUrl || "").trim();

  const imageMarkup = project.image
    ? `
      <img
        class="project-image"
        src="${escapeAttribute(project.image)}"
        alt="${escapeAttribute(
          project.imageAlt || ""
        )}"
        loading="lazy"
      >
    `
    : "";

  const employerMarkup = project.employer
    ? `
      <p class="project-employer">
        ${escapeHtml(project.employer)}
      </p>
    `
    : "";

  const metricMarkup = project.featuredMetric
    ? `
      <p class="project-metric">
        ${escapeHtml(project.featuredMetric)}
      </p>
    `
    : "";

  const actionMarkup = pageUrl
    ? `
      <span
        class="project-card-action"
        aria-hidden="true"
      >
        View project
        <span class="project-card-arrow">
          →
        </span>
      </span>
    `
    : "";

  const tagsMarkup = (project.tags || [])
    .map((tag) => {
      return `
        <span class="project-tag">
          ${escapeHtml(tag)}
        </span>
      `;
    })
    .join("");

  const cardContents = `
    ${imageMarkup}

    <div class="project-content">
      ${employerMarkup}

      <h3>
        ${escapeHtml(
          project.title || "Untitled project"
        )}
      </h3>

      <p class="project-summary">
        ${escapeHtml(project.summary || "")}
      </p>

      ${metricMarkup}

      ${actionMarkup}

      <div class="project-tags">
        ${tagsMarkup}
      </div>
    </div>
  `;

  if (pageUrl) {
    return `
      <a
        class="project-card project-card-link"
        href="${escapeAttribute(pageUrl)}"
        aria-label="View project: ${escapeAttribute(
          project.title || "Project"
        )}"
      >
        ${cardContents}
      </a>
    `;
  }

  return `
    <article class="project-card">
      ${cardContents}
    </article>
  `;
}

/*
  Filters, sorts and displays the project library.
*/

function renderProjects() {
  if (!elements.grid) {
    return;
  }

  const matchingProjects =
    state.projects.filter((project) => {
      return (
        projectMatchesSelectedTags(project) &&
        projectMatchesSearch(project)
      );
    });

  const visibleProjects =
    sortProjects(matchingProjects);

  const projectWord =
    visibleProjects.length === 1
      ? "project"
      : "projects";

  if (elements.resultCount) {
    elements.resultCount.textContent =
      `${visibleProjects.length} ${projectWord}`;
  }

  if (elements.activeFilterSummary) {
    if (state.selectedTags.size > 0) {
      elements.activeFilterSummary.textContent =
        [...state.selectedTags].join(" + ");
    } else if (state.searchQuery.trim()) {
      elements.activeFilterSummary.textContent =
        `Search: “${state.searchQuery.trim()}”`;
    } else {
      elements.activeFilterSummary.textContent =
        "Showing all work";
    }
  }

  if (elements.emptyState) {
    elements.emptyState.hidden =
      visibleProjects.length !== 0;
  }

  elements.grid.innerHTML = visibleProjects
    .map((project) => {
      return createProjectCard(project);
    })
    .join("");

  elements.grid.scrollTop = 0;
}

/*
  Loads the project database.
*/

async function loadProjects() {
  try {
    const response = await fetch(
      "data/projects.json",
      {
        cache: "no-store"
      }
    );

    if (!response.ok) {
      throw new Error(
        `Unable to load projects.json: ${
          response.status
        }`
      );
    }

    const projectData = await response.json();

    if (!Array.isArray(projectData)) {
      throw new Error(
        "projects.json must contain a JSON array."
      );
    }

    /*
      Store a prepared search index with every
      project so repeated searches stay responsive.
    */

    state.projects = projectData.map((project) => {
      return {
        ...project,
        _searchData:
          buildProjectSearchData(project)
      };
    });

    renderProjects();
  } catch (error) {
    console.error(error);

    if (elements.resultCount) {
      elements.resultCount.textContent =
        "Projects could not be loaded";
    }

    if (elements.grid) {
      elements.grid.innerHTML = `
        <div class="empty-state">
          <h3>
            Projects could not be loaded
          </h3>

          <p>
            Check that data/projects.json exists
            and contains valid JSON.
          </p>
        </div>
      `;
    }
  }
}

/*
  Search event.
*/

if (elements.search) {
  elements.search.addEventListener(
    "input",
    (event) => {
      state.searchQuery = event.target.value;

      renderProjects();
    }
  );
}

/*
  Sort event.
*/

if (elements.sort) {
  elements.sort.addEventListener(
    "change",
    (event) => {
      state.sortOrder = event.target.value;

      renderProjects();
    }
  );
}

/*
  Clear filters and search together.
*/

if (elements.clearFilters) {
  elements.clearFilters.addEventListener(
    "click",
    () => {
      state.selectedTags.clear();
      state.searchQuery = "";

      if (elements.search) {
        elements.search.value = "";
      }

      updateFilterButtons();
      renderProjects();
    }
  );
}

/*
  Current footer year.
*/

if (elements.currentYear) {
  elements.currentYear.textContent =
    new Date().getFullYear();
}

/*
  Start the portfolio.
*/

createFilterButtons();
updateFilterButtons();
loadProjects();
